<div class="row justify-content-center mt-5">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-dark text-white py-3 text-center">
        <h1 class="h4 mb-0"><i class="bi bi-lock-fill me-2"></i>Admin Sign In</h1>
      </div>
      <div class="card-body p-4">
        
        <%= form_with url: login_path, local: true do |f| %>
          
          <div class="mb-3">
            <%= f.label :email, class: "form-label fw-bold" %>
            <%= f.email_field :email, class: "form-control", placeholder: "admin@example.com", required: true %>
          </div>

          <div class="mb-4">
            <%= f.label :password, class: "form-label fw-bold" %>
            <%= f.password_field :password, class: "form-control", required: true %>
          </div>

          <div class="d-grid">
            <%= f.submit "Login", class: "btn btn-primary btn-lg" %>
          </div>

        <% end %>

      </div>
    </div>
  </div>
</div>