<!-- Page Header & Action Buttons -->
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
  <div>
    <h1 class="display-6 fw-bold text-dark mb-1">Event Dashboard</h1>
    <p class="text-secondary mb-0">Manage your market schedules and registered vendors.</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to new_event_path, class: 'btn btn-primary d-inline-flex align-items-center' do %>
      <i class="bi bi-calendar-plus me-2"></i>Create New Event
    <% end %>
    <%= link_to new_vendor_path, class: 'btn btn-dark d-inline-flex align-items-center' do %>
      <i class="bi bi-person-plus me-2"></i>Add New Vendor
    <% end %>
  </div>
</div>

<!-- SECTION 1: UPCOMING EVENTS -->
<h3 class="h4 mb-3 text-dark fw-semibold d-flex align-items-center">
  <i class="bi bi-calendar2-check me-2 text-primary"></i>Upcoming Events
</h3>

<div class="card shadow-sm border-0 overflow-hidden mb-5">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-dark">
        <tr>
          <th scope="col" class="ps-4">Event Title</th>
          <th scope="col">Date</th>
          <th scope="col">Location</th>
          <th scope="col" class="text-center pe-4">Vendors Count</th>
        </tr>
      </thead>
      <tbody>
        <% if @events.any? %>
          <% @events.each do |event| %>
            <tr>
              <td class="ps-4">
                <%= link_to event_path(event), class: 'text-decoration-none fw-semibold text-dark dashboard-link' do %>
                  <%= event.title %> <i class="bi bi-arrow-right small text-primary opacity-0 hover-show"></i>
                <% end %>
              </td>
              <td class="text-secondary">
                <i class="bi bi-calendar3 me-1 small"></i>
                <%= event.date.strftime("%B %d, %Y") %>
              </td>
              <td class="text-secondary">
                <i class="bi bi-geo-alt me-1 small"></i>
                <%= event.location %>
              </td>
              <td class="text-center pe-4">
                <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 border border-primary-subtle fw-bold">
                  <i class="bi bi-people-fill me-1"></i><%= event.vendors.count %>
                </span>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="text-center text-muted py-5">
              <i class="bi bi-calendar-x display-6 mb-2 d-block text-black-50"></i>
              No upcoming events at this time.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>


<!-- SECTION 2: PAST EVENTS (LIMIT 15) -->
<h3 class="h4 mb-3 text-dark fw-semibold d-flex align-items-center">
  <i class="bi bi-clock-history me-2 text-secondary"></i>Past Events History
</h3>

<div class="card shadow-sm border-0 overflow-hidden">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-secondary text-dark">
        <tr>
          <th scope="col" class="ps-4">Event Title</th>
          <th scope="col">Date</th>
          <th scope="col">Location</th>
          <th scope="col" class="text-center pe-4">Total Vendors</th>
        </tr>
      </thead>
      <tbody>
        <% past_events = Event.where("date < ?", Date.current).order(date: :desc).limit(15) %>
        
        <% if past_events.any? %>
          <% past_events.each do |event| %>
            <tr class="table-light-subtle">
              <td class="ps-4">
                <%= link_to event_path(event), class: 'text-decoration-none fw-semibold text-secondary dashboard-link' do %>
                  <%= event.title %> <i class="bi bi-arrow-right small text-secondary opacity-0 hover-show"></i>
                <% end %>
              </td>
              <td class="text-muted">
                <i class="bi bi-calendar3 me-1 small"></i>
                <%= event.date.strftime("%B %d, %Y") %>
              </td>
              <td class="text-muted">
                <i class="bi bi-geo-alt me-1 small"></i>
                <%= event.location %>
              </td>
              <td class="text-center pe-4">
                <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2 border border-secondary-subtle fw-bold">
                  <i class="bi bi-people-fill me-1"></i><%= event.vendors.count %>
                </span>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="text-center text-muted py-4">
              No previous event history found.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
  .dashboard-link:hover .hover-show { opacity: 1 !important; transition: opacity 0.2s ease-in-out; }
</style>